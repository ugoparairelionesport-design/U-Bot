run = "npm start"
entrypoint = "index.js" # Assure-toi que c'est bien index.js
modules = ["nodejs-20"]

[nix]
channel = "stable-23_11"

[[ports]]
localPort = 8080
externalPort = 8080

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm start"